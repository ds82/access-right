{
  "name": "access-right",
  "description": "A tiny helper library to handle access rights in your node backend",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "jest",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint src",
    "build": "tsc",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ds82/access-right.git"
  },
  "keywords": [
    "access",
    "right",
    "user",
    "authentication",
    "node",
    "backend",
    "express"
  ],
  "author": "Dennis Saenger <npm15@mail.ds82.de>",
  "license": "MIT",
  "dependencies": {
    "effect": "3.15.1"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@types/jest": "25.2.3",
    "eslint": "^6.6.0",
    "eslint-config-ds82": "2.1.0",
    "ghooks": "0.3.2",
    "jest": "25.5.4",
    "semantic-release": "^15.13.28",
    "typescript": "5.8.3",
    "validate-commit-msg": "1.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "config": {
    "ghooks": {
      "commit-msg": "./node_modules/.bin/validate-commit-msg"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "js", "json", "jsx", "tsx", "node"]
  },
  "version": "v2.0.3"
}
